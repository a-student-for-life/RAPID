# Firebase config — copy values from Firebase Console → Project Settings → Your apps → SDK setup
# Required for real-time crew sync (Firestore) and push notifications (FCM).
# Without these, RAPID falls back to localStorage-only cross-tab sync.

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# VAPID key for FCM web push — Firebase Console → Project Settings → Cloud Messaging → Web push certificates
VITE_FIREBASE_VAPID_KEY=your_vapid_key_here

# Map provider.
# Use leaflet for the free OpenStreetMap/Leaflet map on Firebase Spark/free plans.
# Use google only when Google Maps Platform billing is active and a Maps key is set.
VITE_MAP_PROVIDER=leaflet
VITE_GOOGLE_MAPS_API_KEY=

# Backend URL (leave blank in dev — Vite proxies /api to localhost:8000 automatically).
# In production, set this to your Render/Cloud Run backend URL so the built bundle
# routes /api/* calls to the right place, e.g.:
#   VITE_API_URL=https://rapid-backend-ihde.onrender.com
VITE_API_URL=
