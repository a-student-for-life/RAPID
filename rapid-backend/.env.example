# ── AI routing ────────────────────────────────────────────────────────────────

# Gemini API key — free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here
GEMINI_TIMEOUT_SECONDS=10.0

# Groq API key — free at https://console.groq.com/keys
# Used as AI fallback when Gemini is unavailable/quota-exceeded
GROQ_API_KEY=your_groq_key_here
GROQ_TIMEOUT_SECONDS=15.0
# GROQ_AGENTIC=true  — set false to use single-prompt mode (faster, less reasoning)
GROQ_AGENTIC=true

# ── ETA routing ───────────────────────────────────────────────────────────────

# OpenRouteService API key — free at https://openrouteservice.org (2000 req/day)
# Gives real road-network ETAs. Falls back to haversine simulation if not set.
ORS_API_KEY=your_ors_key_here

# ── Firebase / Firestore ──────────────────────────────────────────────────────

# Your Firebase project ID (visible in Firebase Console → Project Settings)
GOOGLE_CLOUD_PROJECT=your-firebase-project-id

# Path to your Firebase service account key JSON
# Download from: Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# If Firestore / Firebase is not configured, RAPID operates fine in local mode —
# incidents are NOT persisted and crew sync falls back to localStorage only.
