# Gemini API key — get a free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here
GEMINI_TIMEOUT_SECONDS=30.0

# Groq API key — get a free key from https://console.groq.com/keys
# Used as AI fallback when Gemini is unavailable/quota-exceeded
GROQ_API_KEY=your_groq_key_here
GROQ_TIMEOUT_SECONDS=15.0
