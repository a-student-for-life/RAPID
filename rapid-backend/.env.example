# Google Cloud project ID (required for Gemini + Firestore)
GOOGLE_CLOUD_PROJECT=your-project-id

# Path to service account key for local development
# (not required on Cloud Run — uses attached service account)
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# Gemini AI timeout in seconds (default 8.0)
# Set to a very low value (e.g. 0.001) to force FALLBACK mode for demos
GEMINI_TIMEOUT_SECONDS=8.0
