# When these thresholds are hit, system silently falls back to OSS stack.
# Defaults are conservative (well inside $200/month credit at demo scale).
# GOOGLE_ROUTES_DAILY_LIMIT=800
# GOOGLE_PLACES_DAILY_LIMIT=400
# GOOGLE_GEOCODE_DAILY_LIMIT=300

# Optional: Google Cloud Text-to-Speech (for crew alert voice readout feature)
GOOGLE_TTS_API_KEY=./rapidtts-e8121-9ab23690a133.json

# ── ETA routing (OSS fallback — always available) ─────────────────────────────

