# ── AI routing ────────────────────────────────────────────────────────────────

# Groq API key — free at https://console.groq.com/keys
# PRIMARY AI routing model (Llama-3.3-70b, ~500K tokens/day free tier)
GROQ_API_KEY=your_groq_key_here
GROQ_TIMEOUT_SECONDS=15.0
# GROQ_AGENTIC=true  — set false to use single-prompt mode (faster, less reasoning)
GROQ_AGENTIC=true

# Gemini API key — free at https://aistudio.google.com/apikey
# FALLBACK AI routing (Gemini 1.5 Flash) + Vision scene assessment feature
GEMINI_API_KEY=your_gemini_key_here
GEMINI_TIMEOUT_SECONDS=10.0

# ── Google Maps Platform (Financial Circuit Breaker) ──────────────────────────
# Get your key at: https://console.cloud.google.com/google/maps-apis
# Enable: Maps JavaScript API, Places API, Routes API
# $200/month renewable credit covers all Maps usage at demo scale.
#
# If NOT set: system automatically uses the free OSS stack (Leaflet + Nominatim + ORS).
# If set: Google APIs used as primary with OSS fallback on quota/rate-limit errors.
