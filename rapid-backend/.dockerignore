# Never bake secrets into the image — Cloud Run gets secrets via env vars /
# Secret Manager, and the runtime service account handles Firestore auth.
.env
.env.*
!.env.example
*.json
!package.json
!tsconfig.json
serviceAccountKey*
rapid-e8121-*.json
rapidtts-e8121-*.json

# Local dev junk
__pycache__
*.pyc
*.pyo
.pytest_cache
pytest-cache-files-*
.mypy_cache
.ruff_cache
.coverage
htmlcov
.venv
venv

# Tests and local tools — don't ship with the runtime image.
tests
test_*.py
seed_firestore.py

# Editor + VCS noise
.git
.gitignore
.vscode
.idea
*.swp
.DS_Store
